{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "BDSeguridad": "Data Source=.;Initial Catalog=Productos;Integrated Security=True"
  },
  "AllowedHosts": "*",
  "ApiEndpoints": {
    "UrlBase": "https://localhost:7283/api",
    "Metodos": [
      {
        "Nombre": "ObtenerProductos",
        "Valor": "producto"
      },
      {
        "Nombre": "ObtenerCategorias",
        "Valor": "categoria"
      },
      {
        "Nombre": "ObtenerSubCategorias",
        "Valor": "subCategoria/{0}"
      },
      {
        "Nombre": "ObtenerProducto",
        "Valor": "producto/{0}"
      },
      {
        "Nombre": "AgregarProducto",
        "Valor": "producto"
      },
      {
        "Nombre": "EditarProducto",
        "Valor": "producto/{0}"
      },
      {
        "Nombre": "EliminarProducto",
        "Valor": "producto/{0}"
      }
    ]
  },
  "ApiEndPointsSeguridad": {
    "UrlBase": "https://localhost:7253/api",
    "Metodos": [
      {
        "Nombre": "Login",
        "Valor": "autenticacion/login"
      },
      {
        "Nombre": "Registro",
        "Valor": "usuario/registrarusuario"
      }

    ]
  }
}
